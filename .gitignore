.env

# UniVRM embedded packages (referenced via git URL in manifest.json instead)
unity/aivatar/Packages/com.vrmc.gltf/
unity/aivatar/Packages/com.vrmc.vrm/

# Unity generated directories
unity/aivatar/Library/
unity/aivatar/Temp/
unity/aivatar/Logs/
unity/aivatar/obj/
unity/aivatar/UserSettings/

# Unity generated project/solution files
unity/aivatar/*.csproj
unity/aivatar/*.sln
unity/aivatar/UpgradeLog.htm

# OS
.DS_Store
Thumbs.db

# VS Code
.vscode/

# Python virtual environment
.venv/

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Runtime debug logs
debug/logs/

# Persistent conversation sessions (runtime data, not source)
sessions/
