# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Unity-specific binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.bmp binary
*.tga binary
*.tiff binary
*.psd binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.mp3 binary
*.wav binary
*.ogg binary
*.fbx binary
*.obj binary
*.blend binary
*.asset binary
*.prefab binary
*.unity binary
*.mat binary
*.anim binary
*.controller binary
*.dll binary
*.pdb binary
*.so binary
*.dylib binary
*.exe binary
*.unitypackage binary

# Force LF for code and text files
*.cs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.py text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.env text eol=lf
*.shader text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.glsl text eol=lf
